# --- Supabase Postgres ---
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# 형식: postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/prombutter

# --- Firebase Auth (인증 전용 — DB는 Supabase 사용) ---
# Firebase Console → Project Settings → Service accounts → Generate new private key
# 다운로드한 JSON 의 project_id 와, JSON 파일 경로(또는 JSON 전체 문자열) 를 환경변수로 주입
FIREBASE_PROJECT_ID=prombutter-xxxxx
# 둘 중 하나만 사용:
# (A) 로컬: 서비스 계정 JSON 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-admin.json
# (B) Cloud Run/배포: JSON 전체를 한 줄 문자열로
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- App ---
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://frontend-prombutters-projects.vercel.app

# --- GCP (Google Cloud Platform) ---
# GCP Console → 프로젝트 ID 와 Cloud Storage 버킷 이름
GCP_PROJECT_ID=prombutter-xxxxx
GCP_STORAGE_BUCKET=prombutter-bucket-name
